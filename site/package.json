{
  "name": "pndtools-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:content && astro build",
    "build:content": "cp -r ../docs/. src/content/docs/ && node scripts/add-api-frontmatter.mjs && node scripts/add-benchmark-frontmatter.mjs",
    "build:watch": "npm run build:content && astro dev",
    "start": "astro dev",
    "start:preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.3.1"
  }
}
