{
  "name": "pndtools-site",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:content && astro build",
    "build:clean": "rm -rf .astro dist ../BenchmarkDotNet.Artifacts ../docs/benchmarks/*-report-github.md ../docs/coverage/SummaryGithub.md",
    "build:content": "node scripts/add-benchmark-frontmatter.mjs && node scripts/add-coverage-frontmatter.mjs",
    "build:watch": "npm run build:content && astro dev",
    "start": "astro dev",
    "start:preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.39.3",
    "astro": "^6.4.4"
  }
}
